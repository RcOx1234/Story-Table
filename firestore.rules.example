rules_version = '2';

// Copia este contenido en la consola de Firebase → Firestore → Reglas.
// Sustituye cualquier regla `allow read, write: if false` que bloquee todo.

service cloud.firestore {
  match /databases/{database}/documents {
    // Cada usuario solo accede a su propia árbol bajo users/{uid}/...
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
