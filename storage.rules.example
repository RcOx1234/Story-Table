rules_version = '2';

// Copia en Firebase Console → Storage → Reglas.
// Reemplaza `allow read, write: if false` que bloquea todo.

service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
